{
  "skill_id": "yao-geoflow-template",
  "required_files": [
    "SKILL.md",
    "agents/interface.yaml",
    "evals/trigger_cases.json",
    "evals/expected_artifacts.json",
    "evals/rubric.md",
    "evals/failure_cases.md",
    "references/geoflow-frontend-map.md",
    "references/template-boundary.md",
    "references/theme-package-contract.md"
  ],
  "primary_outputs": [
    "theme-package-plan",
    "tokens-json",
    "mapping-json",
    "preview-plan"
  ],
  "standardized_preview_package": {
    "example_entrypoint": "examples/<example-id>/README.md",
    "preview_root": "preview/<example-id>/",
    "metadata_files": [
      "preview/<example-id>/package/tokens.json",
      "preview/<example-id>/package/mapping.json"
    ],
    "preview_routes": [
      "preview/<example-id>/index.html",
      "preview/<example-id>/category.html",
      "preview/<example-id>/article.html",
      "preview/<example-id>/archive.html"
    ],
    "required_tokens_fields": [
      "id",
      "name",
      "source_reference_url",
      "created_at",
      "compatible_system",
      "style_direction",
      "tokens"
    ],
    "required_mapping_fields": [
      "id",
      "name",
      "mvp_order",
      "compatible_pages",
      "module_mapping",
      "safe_boundaries",
      "preview_routes"
    ]
  },
  "quality_expectations": [
    "must begin from GEOFlow's existing frontend contract",
    "must preserve routing, SEO, and data-query boundaries unless explicitly expanded",
    "must prefer preview-first template packages over direct production replacement",
    "must map reference styles onto GEOFlow modules instead of copying raw pages verbatim",
    "must keep committed public previews self-contained with committed package metadata",
    "must not depend on ignored outputs/ or outputs-demo/ paths for public examples"
  ]
}
